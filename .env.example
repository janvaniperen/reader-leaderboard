# Beehiiv API credentials
# Get an API key at: https://app.beehiiv.com/settings/integrations/api
BEEHIIV_API_KEY=

# Beehiiv publication ID (starts with pub_)
# Find in Beehiiv → Settings → Publication, or via the API
BEEHIIV_PUBLICATION_ID=

# A random string used to authorise manual /api/refresh calls.
# Generate one with: openssl rand -hex 32
REFRESH_SECRET=

# logo.dev publishable token (pk_...) for company logos in the widget.
# Sign up at https://logo.dev — safe to expose to the browser; we serve it via /api/config.
LOGO_DEV_TOKEN=

# Auto-populated by Vercel when you enable Cron — do not set manually
# CRON_SECRET=

# Vercel KV connection — auto-populated when you connect a KV store via the dashboard
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_URL=
