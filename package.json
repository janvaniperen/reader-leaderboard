{
  "name": "reader-leaderboard",
  "version": "0.1.0",
  "description": "A hosted, embeddable leaderboard of the companies subscribed to a Beehiiv newsletter.",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "USE_LOCAL_CACHE=1 vercel dev --listen 3000 --yes",
    "serve:mock": "MOCK_LEADERBOARD=1 vercel dev --listen 3000 --yes",
    "deploy": "vercel --prod",
    "test": "node --test test/**/*.test.js",
    "lint": "eslint api lib test eslint.config.js"
  },
  "dependencies": {
    "@vercel/kv": "3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.28.0",
    "eslint": "9.28.0",
    "globals": "16.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
